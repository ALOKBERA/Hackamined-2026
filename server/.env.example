PORT=5000
NODE_ENV=development

# MongoDB
# MongoDB Atlas URI (free at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/snapsense?retryWrites=true&w=majority

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Session
SESSION_SECRET=your_super_secret_session_key_here_change_in_production

# Groq AI
GROQ_API_KEY=your_groq_api_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
